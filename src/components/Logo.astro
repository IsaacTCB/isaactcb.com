---
import Avatar from "../assets/bg/checker.svg";
---

<div class="flex flex-col items-center justify-center text-3xl">
    <div class="md:-ml-8 flex flex-row items-center justify-center gap-6">
        <Avatar
            class="hidden md:block rounded-xl outline-1 outline-black/10 ring ring-accent-900/20 w-24 h-24 shadow-md shadow-accent-500/20"
        />
        <h1
            class="-mb-2 text-8xl font-bold tracking-[-0.075em] text-accent-600 dark:text-accent-100 text-shadow-sm text-shadow-accent-200/20 dark:text-shadow-accent-500/20"
        >
            isaactcb
        </h1>
    </div>
    <div
        class="md:ml-12 mt-3 slogan flex justify-end gap-2 text-lg text-accent-800 dark:text-accent-500 select-none"
    >
        <i>”hi! welcome to my website!”</i>
    </div>
</div>
